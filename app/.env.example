# ============================================================
# Raitha Bharosa – Environment Configuration Template
# Copy this file to app/.env and fill in your credentials.
# DO NOT commit the actual .env file.
# ============================================================

# Agmarknet (data.gov.in) API Key
# Get at: https://data.gov.in/resource/current-daily-price-various-commodities-various-markets-mandi
AGMARKNET_API_KEY=your_agmarknet_api_key_here

# OpenWeatherMap API Key
# Get at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Twilio SMS API Credentials
# Get at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx

# WhatsApp Business API Credentials
# Get at: https://developers.facebook.com/docs/whatsapp
WHATSAPP_API_KEY=EAAxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345

# Razorpay Payment Gateway
# Get at: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
